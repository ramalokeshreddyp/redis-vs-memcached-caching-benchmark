# Product Catalog API Configuration
API_PORT=3000

# Cache Backend URLs
REDIS_URL=redis://localhost:6379
MEMCACHED_URL=localhost:11211

# Relational Database connection URI
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/catalog

# Default cache backend to use if X-Cache-Backend header is missing (redis or memcached)
DEFAULT_CACHE_BACKEND=redis
